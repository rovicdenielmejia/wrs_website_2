generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  RECRUITER
  EMPLOYER
  CANDIDATE
}

enum JobStatus {
  DRAFT
  ACTIVE
  CLOSED
  ARCHIVED
}

enum ApplicationStatus {
  APPLIED
  SCREENING
  INTERVIEW
  OFFER
  HIRED
  REJECTED
  WITHDRAWN
}

enum JobType {
  FULL_TIME
  PART_TIME
  CONTRACT
  REMOTE
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  password      String
  firstName     String
  lastName      String
  phone         String?
  role          Role      @default(CANDIDATE)
  avatar        String?
  emailVerified DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  employer      Employer?
  applicant     Applicant?
  consultations Consultation[]
  blogs         Blog[]
  comments      Comment[]
  activities    Activity[]

  @@index([email])
  @@index([role])
}

model Employer {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyName String
  industry    String
  website     String?
  description String?
  logo        String?
  size        String?
  location    String?
  isVerified  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  jobs         Job[]
  consultations Consultation[]

  @@index([userId])
  @@index([companyName])
}

model Applicant {
  id           String   @id @default(cuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  headline     String?
  summary      String?
  resume       String?
  resumeUrl    String?
  skills       String[]
  experience   Int?
  education    String?
  linkedin     String?
  location     String?
  preferredLocation String?
  preferredJobType  JobType?
  salaryExpectation Int?
  isAvailable  Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  applications Application[]
  talents      Talent[]

  @@index([userId])
  @@index([skills])
}

model Talent {
  id              String   @id @default(cuid())
  applicantId     String
  applicant       Applicant @relation(fields: [applicantId], references: [id], onDelete: Cascade)
  name            String
  email           String
  phone           String?
  location        String?
  experience      String?
  skills          String[]
  currentCompany  String?
  currentPosition String?
  source          String?
  notes           String?
  status          String   @default("new")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([applicantId])
  @@index([status])
}

model Job {
  id              String     @id @default(cuid())
  employerId      String
  employer        Employer   @relation(fields: [employerId], references: [id], onDelete: Cascade)
  title           String
  slug            String     @unique
  location        String
  experience      String
  salaryRange     String?
  description     String     @db.Text
  responsibilities String[]   @default([])
  requiredSkills  String[]   @default([])
  benefits        String[]   @default([])
  additionalInfo  String?    @db.Text
  industry        String
  jobType         JobType
  status          JobStatus  @default(DRAFT)
  featured        Boolean    @default(false)
  viewCount       Int        @default(0)
  applyFormUrl    String?
  imageUrl        String?
  publishedAt     DateTime?
  expiresAt       DateTime?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  applications    Application[]
  categories      Category[]   @relation("JobCategories")

  @@index([employerId])
  @@index([status])
  @@index([jobType])
  @@index([industry])
  @@index([slug])
  @@index([featured])
}

model Application {
  id             String            @id @default(cuid())
  jobId          String
  job            Job               @relation(fields: [jobId], references: [id], onDelete: Cascade)
  applicantId    String?
  applicant      Applicant?        @relation(fields: [applicantId], references: [id], onDelete: SetNull)
  
  name           String
  email          String
  phone          String?
  coverLetter    String?           @db.Text
  resumeUrl      String?
  
  status         ApplicationStatus @default(APPLIED)
  statusNotes    String?
  interviewDate  DateTime?
  interviewNotes String?
  
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@index([jobId])
  @@index([applicantId])
  @@index([status])
  @@index([email])
}

model EmployerProfile {
  id           String   @id @default(cuid())
  companyName  String
  contactName  String
  email        String
  phone        String?
  industry     String
  companySize  String?
  location     String?
  description  String?  @db.Text
  website      String?
  logo         String?
  isVerified   Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([companyName])
}

model Consultation {
  id           String    @id @default(cuid())
  userId       String?
  user         User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  employerId   String?
  employer     Employer? @relation(fields: [employerId], references: [id], onDelete: SetNull)
  
  name         String
  email        String
  phone        String?
  company      String?
  type         String?
  message      String?   @db.Text
  service      String?
  
  status       String    @default("pending")
  notes        String?   @db.Text
  scheduledAt  DateTime?
  
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([userId])
  @@index([email])
  @@index([status])
}

model Blog {
  id           String    @id @default(cuid())
  authorId     String
  author       User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  
  title        String
  slug         String    @unique
  excerpt      String?
  content      String    @db.Text
  imageUrl     String?
  
  categoryId   String?
  category     Category? @relation("BlogCategories", fields: [categoryId], references: [id])
  
  tags         String[]
  seoTitle     String?
  seoDescription String?
  
  published    Boolean   @default(false)
  publishedAt  DateTime?
  
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  comments     Comment[]

  @@index([authorId])
  @@index([slug])
  @@index([published])
  @@index([categoryId])
}

model Category {
  id      String  @id @default(cuid())
  name    String  @unique
  slug    String  @unique
  description String?
  
  jobs    Job[]   @relation("JobCategories")
  blogs   Blog[]  @relation("BlogCategories")
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([slug])
}

model Comment {
  id        String   @id @default(cuid())
  blogId    String
  blog      Blog     @relation(fields: [blogId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  
  content   String   @db.Text
  isApproved Boolean  @default(true)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([blogId])
  @@index([authorId])
}

model Activity {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  type      String
  action    String
  entity    String?
  entityId  String?
  metadata  Json?
  
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([type])
}

model Inquiry {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  subject   String?
  message   String   @db.Text
  
  status    String   @default("new")
  notes     String?
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@index([status])
}

model Newsletter {
  id        String   @id @default(cuid())
  email     String   @unique
  isActive  Boolean  @default(true)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Page {
  id        String   @id @default(cuid())
  title     String
  slug      String   @unique
  content   String   @db.Text
  seoTitle  String?
  seoDescription String?
  
  published Boolean  @default(false)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([slug])
}

model Faq {
  id        String   @id @default(cuid())
  question  String
  answer    String   @db.Text
  category  String?
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
}
