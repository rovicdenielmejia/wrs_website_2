{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    { "source": "/", "destination": "/home.html" },
    { "source": "/index.html", "destination": "/home.html" },
    { "source": "/WorkforceRecruitmentSolution.html", "destination": "/home.html" }
  ],
  "redirects": [
    { "source": "/why-us", "destination": "/why-us.html", "permanent": true },
    { "source": "/services", "destination": "/services.html", "permanent": true },
    { "source": "/hr-services", "destination": "/hr-services.html", "permanent": true },
    { "source": "/recruitment-process", "destination": "/recruitment-process.html", "permanent": true },
    { "source": "/enterprise-global", "destination": "/enterprise-global.html", "permanent": true },
    { "source": "/platform", "destination": "/platform.html", "permanent": true },
    { "source": "/pricing", "destination": "/pricing.html", "permanent": true },
    { "source": "/about", "destination": "/about.html", "permanent": true },
    { "source": "/jobs", "destination": "/jobs.html", "permanent": true },
    { "source": "/faq", "destination": "/faq.html", "permanent": true },
    { "source": "/blogs", "destination": "/blogs.html", "permanent": true },
    { "source": "/privacy", "destination": "/privacy.html", "permanent": true },
    { "source": "/terms", "destination": "/terms.html", "permanent": true },
    { "source": "/book-consultation", "destination": "/book-consultation.html", "permanent": true }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "geolocation=(), microphone=(), camera=()" }
      ]
    },
    {
      "source": "/(.*)\\.html",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600, must-revalidate" }
      ]
    },
    {
      "source": "/(.*)\\.css",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*)\\.js",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/Assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
