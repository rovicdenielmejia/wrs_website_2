# Database
DATABASE_URL="postgresql://username:password@host:5432/wrs_db?schema=public"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-super-secret-key-generate-with-openssl-rand-base64-32"

# OAuth (Optional)
